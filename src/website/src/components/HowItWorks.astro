---
import { useTranslations } from '../i18n/utils';
import CodeBlock from './CodeBlock.astro';
import TabbedCodeBlock from './TabbedCodeBlock.astro';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const sdkTabs = [
  {
    label: t.howItWorks.sdkTabPython,
    lang: 'python',
    filename: 'settings.py',
    code: `from envilder import Envilder

# One-liner: load secrets into os.environ
Envilder.load("param-map.json")

# Or resolve as a dict without injecting
secrets = Envilder.from_file("param-map.json").resolve()`,
  },
  {
    label: t.howItWorks.sdkTabDotnet,
    lang: 'csharp',
    filename: 'Program.cs',
    code: `using Envilder;

// Load into IConfiguration
var mapFile = new MapFileParser().Parse(
    File.ReadAllText("param-map.json"));
var provider = SecretProviderFactory.Create(mapFile.Config);
builder.Configuration.AddEnvilder("param-map.json", provider);

// Or resolve + inject into environment
var client = new EnvilderClient(provider);
var secrets = await client.ResolveSecretsAsync(mapFile);
EnvilderClient.InjectIntoEnvironment(secrets);`,
  },
];
---

<section class="section section-alt" id="how-it-works">
  <div class="container">
    <div class="section-title">
      <h2>{t.howItWorks.title}<span>{t.howItWorks.titleAccent}</span></h2>
      <p class="section-subtitle">
        {t.howItWorks.subtitle}
      </p>
    </div>

    <div class="steps">
      <div class="step">
        <div class="step-number">
          <span class="step-label">{t.howItWorks.stepLabel}</span>
          <span>01</span>
        </div>
        <div class="step-content">
          <h3>{t.howItWorks.steps[0].title}</h3>
          <p>
            {t.howItWorks.steps[0].description}
          </p>
          <CodeBlock lang="json" filename="param-map.json" code={`{
  "DB_PASSWORD": "/my-app/prod/db-password",
  "API_KEY":     "/my-app/prod/api-key",
  "SECRET_TOKEN": "/my-app/prod/secret-token"
}`} />
        </div>
      </div>

      <div class="step-connector">
        <span class="connector-line"></span>
        <span class="connector-arrow">▼</span>
        <span class="connector-line"></span>
      </div>

      <div class="step">
        <div class="step-number">
          <span class="step-label">{t.howItWorks.stepLabel}</span>
          <span>02</span>
        </div>
        <div class="step-content">
          <h3>{t.howItWorks.steps[1].title}</h3>
          <p>
            {t.howItWorks.steps[1].description}
          </p>
          <CodeBlock lang="bash" filename="terminal" code={`$ envilder --map=param-map.json --envfile=.env

${t.howItWorks.terminalFetched1}
${t.howItWorks.terminalFetched2}
${t.howItWorks.terminalFetched3}
${t.howItWorks.terminalWritten}`} />
        </div>
      </div>

      <div class="step-connector">
        <span class="connector-line"></span>
        <span class="connector-arrow">▼</span>
        <span class="connector-line"></span>
      </div>

      <div class="step">
        <div class="step-number">
          <span class="step-label">{t.howItWorks.stepLabel}</span>
          <span>03</span>
        </div>
        <div class="step-content">
          <h3>{t.howItWorks.steps[2].title}</h3>
          <p>
            {t.howItWorks.steps[2].description}
          </p>
          <TabbedCodeBlock tabs={sdkTabs} />
        </div>
      </div>

      <div class="step-connector">
        <span class="connector-line"></span>
        <span class="connector-arrow">▼</span>
        <span class="connector-line"></span>
      </div>

      <div class="step">
        <div class="step-number">
          <span class="step-label">{t.howItWorks.stepLabel}</span>
          <span>04</span>
        </div>
        <div class="step-content">
          <h3>{t.howItWorks.steps[3].title}</h3>
          <p>
            {t.howItWorks.steps[3].description}
          </p>
          <CodeBlock lang="bash" filename="terminal" code={`$ envilder --push --envfile=.env --map=param-map.json

${t.howItWorks.pushTerminalPushed1}
${t.howItWorks.pushTerminalPushed2}
${t.howItWorks.pushTerminalPushed3}`} />
        </div>
      </div>

      <div class="step-connector">
        <span class="connector-line"></span>
        <span class="connector-arrow">▼</span>
        <span class="connector-line"></span>
      </div>

      <div class="step step-final">
        <div class="step-number">
          <span class="step-label">{t.howItWorks.stepLabel}</span>
          <span>05</span>
        </div>
        <div class="step-content">
          <h3>{t.howItWorks.steps[4].title}</h3>
          <p>
            {t.howItWorks.steps[4].description}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .steps {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    max-width: 720px;
    margin: 0 auto;
  }

  .step {
    display: flex;
    gap: var(--space-xl);
    width: 100%;
    align-items: flex-start;
    min-width: 0;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    padding: var(--space-lg);
  }

  .step-number {
    flex-shrink: 0;
    width: 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    background: var(--color-primary);
    border: 2px solid var(--color-primary);
    box-shadow: var(--pixel-shadow-primary);
    padding: var(--space-sm) 0;
  }

  .step-label {
    font-family: var(--font-pixel);
    font-size: 0.4rem;
    color: var(--color-btn-text);
    opacity: 0.75;
    letter-spacing: 0.05em;
  }

  .step-number > span:not(.step-label) {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    color: var(--color-btn-text);
  }

  .step-content {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .step-content h3 {
    color: var(--color-text);
    font-size: 1.1rem;
  }

  .step-content p {
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .step-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-sm) 0;
    margin-left: calc(var(--space-lg) + 28px);
    width: 2px;
  }

  .connector-line {
    width: 2px;
    height: 12px;
    background: var(--color-border);
  }

  .connector-arrow {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: var(--color-primary);
    padding: 2px 0;
  }

  @media (max-width: 640px) {
    .step {
      flex-direction: column;
      gap: var(--space-md);
      overflow: hidden;
    }

    .step-connector {
      margin-left: 0;
      flex-direction: row;
      width: auto;
      gap: var(--space-sm);
      padding: var(--space-sm) 0;
    }

    .connector-line {
      width: 16px;
      height: 2px;
    }
  }

  .step-final {
    border-color: var(--color-primary);
  }
</style>
