---
import Footer from '../../components/Footer.astro';
import Navbar from '../../components/Navbar.astro';
import BackToTop from '../../components/BackToTop.astro';
import { localizedPath, useTranslations } from '../../i18n/utils';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { changelogToHtml, extractVersions } from '../../utils/markdown';

const lang = 'es';
const t = useTranslations(lang);

const rawContent: string =
  __CHANGELOG_CONTENT__ ||
  '# Changelog\n\nChangelog not available. See [GitHub Releases](https://github.com/macalbert/envilder/releases).';
const changelogHtml = changelogToHtml(rawContent);
const versions = extractVersions(rawContent);
---

<BaseLayout
  title={t.changelogPage.title}
  lang={lang}
>
  <Navbar lang={lang} />
  <main class="changelog-page">
    <div class="container changelog-layout">

      <aside class="changelog-sidebar">
        <nav class="version-nav">
          <p class="nav-section-title">{t.changelogPage.versions}</p>
          <ul>
            {versions.map((v) => (
              <li>
                <a href={`#${v.id}`}>
                  <span class="version-link-tag">{v.tag}</span>
                  {v.date && <span class="version-link-date">{v.date}</span>}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>

      <div class="changelog-main">
        <div class="changelog-header">
          <a href={localizedPath(lang, '/')} class="back-link">{t.changelogPage.backToHome}</a>
          <h1>{t.changelogPage.fullChangelog}<span class="accent">{t.changelogPage.changelogAccent}</span></h1>
          <p class="changelog-intro">
            {t.changelogPage.intro}
            <a href="https://github.com/macalbert/envilder/releases" target="_blank" rel="noopener noreferrer">
              {t.changelogPage.githubReleases}
            </a>.
          </p>
        </div>
        <article class="changelog-content" set:html={changelogHtml} />
      </div>

    </div>
  </main>
  <BackToTop label={t.changelogPage.backToTop} />
  <Footer lang={lang} />
</BaseLayout>

<style>
  .changelog-page {
    padding-top: calc(var(--nav-height) + var(--space-3xl));
    padding-bottom: var(--space-4xl);
  }

  .changelog-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  @media (min-width: 900px) {
    .changelog-layout {
      grid-template-columns: 200px 1fr;
    }
  }

  .changelog-sidebar {
    display: none;
  }

  @media (min-width: 900px) {
    .changelog-sidebar {
      display: block;
      position: sticky;
      top: calc(var(--nav-height) + var(--space-xl));
      align-self: start;
      max-height: calc(100vh - var(--nav-height) - var(--space-2xl));
      overflow-y: auto;
      padding-right: var(--space-md);
    }
  }

  .nav-section-title {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-dim);
    margin-bottom: var(--space-md);
  }

  .version-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .version-nav a {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all var(--transition-fast);
  }

  .version-nav a:hover {
    color: var(--color-primary);
    border-left-color: var(--color-primary);
    background: var(--color-surface);
  }

  .version-link-tag {
    flex-shrink: 0;
  }

  .version-link-date {
    font-size: 0.68rem;
    color: var(--color-text-dim);
  }

  .changelog-header {
    margin-bottom: var(--space-3xl);
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-text-muted);
    display: inline-block;
    margin-bottom: var(--space-lg);
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .changelog-header h1 {
    margin-bottom: var(--space-md);
  }

  .accent {
    color: var(--color-primary);
  }

  .changelog-intro {
    font-size: 1rem;
    color: var(--color-text-muted);
  }

  .changelog-intro a {
    color: var(--color-secondary);
  }

  .changelog-content {
    max-width: 800px;
  }

  .changelog-content :global(h2) {
    font-family: var(--font-pixel);
    font-size: 0.85rem;
    color: var(--color-primary);
    margin: var(--space-3xl) 0 var(--space-md);
    padding-top: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 2px solid var(--color-border);
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    scroll-margin-top: calc(var(--nav-height) + var(--space-xl));
  }

  .changelog-content :global(h2:first-child) {
    margin-top: 0;
  }

  .changelog-content :global(.version-tag) {
    color: var(--color-text);
  }

  .changelog-content :global(.release-date) {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--color-text-dim);
  }

  .changelog-content :global(h3) {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    color: var(--color-text);
    margin: var(--space-xl) 0 var(--space-sm);
  }

  .changelog-content :global(h4) {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    margin: var(--space-lg) 0 var(--space-sm);
  }

  .changelog-content :global(p) {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .changelog-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-xl) 0;
  }

  .changelog-content :global(ul) {
    list-style: none;
    margin-bottom: var(--space-md);
  }

  .changelog-content :global(li) {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    padding: var(--space-xs) 0;
    padding-left: var(--space-lg);
    position: relative;
  }

  .changelog-content :global(li::before) {
    content: '\203A';
    position: absolute;
    left: var(--space-sm);
    color: var(--color-primary);
    font-weight: bold;
  }

  .changelog-content :global(pre) {
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    padding: var(--space-md);
    overflow-x: auto;
    margin-bottom: var(--space-md);
  }

  .changelog-content :global(pre code) {
    background: none;
    padding: 0;
    border: none;
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  .changelog-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-surface);
    padding: 0.15em 0.4em;
    border: 1px solid var(--color-border);
  }

  .changelog-content :global(a) {
    color: var(--color-secondary);
  }

  .changelog-content :global(strong) {
    color: var(--color-text);
  }
</style>
