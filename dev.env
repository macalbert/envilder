# Development environment variables for local containers
# Source: docker compose -f docker-compose.yml up -d

# AWS SSM (LocalStack)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Azure Key Vault (Lowkey Vault)
NODE_TLS_REJECT_UNAUTHORIZED=0
AZURE_POD_IDENTITY_AUTHORITY_HOST=http://localhost:8080
ENVILDER_ALLOWED_VAULT_HOSTS=localhost
