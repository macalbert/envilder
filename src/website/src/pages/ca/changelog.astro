---
import BackToTop from '../../components/BackToTop.astro';
import Footer from '../../components/Footer.astro';
import Navbar from '../../components/Navbar.astro';
import { localizedPath, useTranslations } from '../../i18n/utils';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { changelogToHtml, extractVersions } from '../../utils/markdown';

const lang = 'ca';
const t = useTranslations(lang);

const fallback = '# Changelog\n\nNo releases yet.';

const products = [
  {
    id: 'cli',
    label: t.changelogPage.categoryCli,
    raw: __CHANGELOG_CLI__ || fallback,
  },
  {
    id: 'sdk-dotnet',
    label: t.changelogPage.categorySdkDotnet,
    raw: __CHANGELOG_SDK_DOTNET__ || fallback,
    group: 'sdks',
  },
  {
    id: 'sdk-python',
    label: t.changelogPage.categorySdkPython,
    raw: __CHANGELOG_SDK_PYTHON__ || fallback,
    group: 'sdks',
  },
  {
    id: 'sdk-typescript',
    label: t.changelogPage.categorySdkTypescript,
    raw: __CHANGELOG_SDK_TYPESCRIPT__ || fallback,
    group: 'sdks',
  },
  {
    id: 'gha',
    label: t.changelogPage.categoryGha,
    raw: __CHANGELOG_GHA__ || fallback,
  },
];

const parsed = products.map((p) => ({
  ...p,
  html: changelogToHtml(p.raw),
  versions: extractVersions(p.raw),
}));
---

<BaseLayout
  title={t.changelogPage.title}
  lang={lang}
>
  <Navbar lang={lang} />
  <main class="changelog-page" id="main-content">
    <div class="container changelog-layout">

      <aside class="changelog-sidebar">
        <nav class="version-nav">
          {/* ── Mobile product selector ── */}
          <div class="product-selector-mobile">
            <select id="product-select-mobile" aria-label={t.changelogPage.versions}>
              {parsed.map((p) => (
                <option value={p.id}>
                  {p.group === 'sdks' ? `SDK → ${p.label}` : p.label}
                </option>
              ))}
            </select>
          </div>

          {/* ── Desktop sidebar ── */}
          <div class="product-nav-desktop">
            {/* CLI */}
            <p class="nav-group-title nav-group-first">{t.changelogPage.categoryCli}</p>
            <button
              class="nav-product-btn nav-product-nested active"
              data-product="cli"
              aria-pressed="true"
              aria-expanded="true"
            >
              <span class="nav-product-chevron">›</span>
              {t.changelogPage.versions}
              <span class="nav-product-count">{parsed[0].versions.length}</span>
            </button>
            <ul class="version-list" data-versions="cli">
              {parsed[0].versions.map((v) => (
                <li>
                  <a href={`#cli-${v.id}`} data-product="cli">
                    <span class="version-link-tag">{v.tag}</span>
                    {v.date && <span class="version-link-date">{v.date}</span>}
                  </a>
                </li>
              ))}
            </ul>

            {/* SDKs group */}
            <p class="nav-group-title">{t.changelogPage.categorySdks}</p>

            {/* .NET */}
            <button
              class="nav-product-btn nav-product-nested"
              data-product="sdk-dotnet"
              aria-pressed="false"
              aria-expanded="false"
            >
              <span class="nav-product-chevron">›</span>
              {t.changelogPage.categorySdkDotnet}
              <span class="nav-product-count">{parsed[1].versions.length}</span>
            </button>
            <ul class="version-list collapsed" data-versions="sdk-dotnet">
              {parsed[1].versions.map((v) => (
                <li>
                  <a href={`#sdk-dotnet-${v.id}`} data-product="sdk-dotnet">
                    <span class="version-link-tag">{v.tag}</span>
                    {v.date && <span class="version-link-date">{v.date}</span>}
                  </a>
                </li>
              ))}
            </ul>

            {/* Python */}
            <button
              class="nav-product-btn nav-product-nested"
              data-product="sdk-python"
              aria-pressed="false"
              aria-expanded="false"
            >
              <span class="nav-product-chevron">›</span>
              {t.changelogPage.categorySdkPython}
              <span class="nav-product-count">{parsed[2].versions.length}</span>
            </button>
            <ul class="version-list collapsed" data-versions="sdk-python">
              {parsed[2].versions.map((v) => (
                <li>
                  <a href={`#sdk-python-${v.id}`} data-product="sdk-python">
                    <span class="version-link-tag">{v.tag}</span>
                    {v.date && <span class="version-link-date">{v.date}</span>}
                  </a>
                </li>
              ))}
            </ul>

            {/* TypeScript */}
            <button
              class="nav-product-btn nav-product-nested"
              data-product="sdk-typescript"
              aria-pressed="false"
              aria-expanded="false"
            >
              <span class="nav-product-chevron">›</span>
              {t.changelogPage.categorySdkTypescript}
              <span class="nav-product-count">{parsed[3].versions.length}</span>
            </button>
            <ul class="version-list collapsed" data-versions="sdk-typescript">
              {parsed[3].versions.map((v) => (
                <li>
                  <a href={`#sdk-typescript-${v.id}`} data-product="sdk-typescript">
                    <span class="version-link-tag">{v.tag}</span>
                    {v.date && <span class="version-link-date">{v.date}</span>}
                  </a>
                </li>
              ))}
            </ul>

            {/* GHA */}
            <p class="nav-group-title">{t.changelogPage.categoryGha}</p>
            <button
              class="nav-product-btn nav-product-nested"
              data-product="gha"
              aria-pressed="false"
              aria-expanded="false"
            >
              <span class="nav-product-chevron">›</span>
              {t.changelogPage.versions}
              <span class="nav-product-count">{parsed[4].versions.length}</span>
            </button>
            <ul class="version-list collapsed" data-versions="gha">
              {parsed[4].versions.map((v) => (
                <li>
                  <a href={`#gha-${v.id}`} data-product="gha">
                    <span class="version-link-tag">{v.tag}</span>
                    {v.date && <span class="version-link-date">{v.date}</span>}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </nav>
      </aside>

      <div class="changelog-main">
        <div class="changelog-header">
          <a href={localizedPath(lang, '/')} class="back-link">{t.changelogPage.backToHome}</a>
          <h1>{t.changelogPage.fullChangelog}<span class="accent">{t.changelogPage.changelogAccent}</span></h1>
          <p class="changelog-intro">
            {t.changelogPage.intro}
            <a href="https://github.com/macalbert/envilder/releases" target="_blank" rel="noopener noreferrer">
              {t.changelogPage.githubReleases}
            </a>.
          </p>
        </div>

        {parsed.map((p, i) => (
          <article
            class="changelog-content"
            data-changelog={p.id}
            style={i > 0 ? 'display:none' : ''}
            set:html={p.html}
          />
        ))}
      </div>

    </div>
  </main>
  <BackToTop label={t.changelogPage.backToTop} />
  <Footer lang={lang} />
</BaseLayout>

<script>
  function initChangelogNav() {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.nav-product-btn');
    const articles = document.querySelectorAll<HTMLElement>('.changelog-content[data-changelog]');
    const versionLists = document.querySelectorAll<HTMLElement>('.version-list[data-versions]');
    const mobileSelect = document.getElementById('product-select-mobile') as HTMLSelectElement | null;

    function switchProduct(productId: string) {
      buttons.forEach((btn) => {
        const isActive = btn.dataset.product === productId;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-pressed', String(isActive));
        btn.setAttribute('aria-expanded', String(isActive));
      });

      versionLists.forEach((ul) => {
        ul.classList.toggle('collapsed', ul.dataset.versions !== productId);
      });

      articles.forEach((article) => {
        article.style.display = article.dataset.changelog === productId ? '' : 'none';
      });

      if (mobileSelect && mobileSelect.value !== productId) {
        mobileSelect.value = productId;
      }
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        if (btn.dataset.product) switchProduct(btn.dataset.product);
      });
    });

    mobileSelect?.addEventListener('change', () => {
      switchProduct(mobileSelect.value);
    });

    // Handle version link clicks — ensure correct product is active
    document.querySelectorAll<HTMLAnchorElement>('.version-list a[data-product]').forEach((link) => {
      link.addEventListener('click', () => {
        if (link.dataset.product) switchProduct(link.dataset.product);
      });
    });
  }

  initChangelogNav();
  document.addEventListener('astro:after-swap', initChangelogNav);
</script>
<style>
  .changelog-page {
    padding-top: calc(var(--nav-height) + var(--space-3xl));
    padding-bottom: var(--space-4xl);
  }

  /* ── Two-column layout ── */
  .changelog-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
  }

  @media (min-width: 900px) {
    .changelog-layout {
      grid-template-columns: 220px 1fr;
    }
  }

  /* ── Sidebar ── */
  .changelog-sidebar {
    /* Mobile: show the dropdown selector only */
  }

  .product-selector-mobile {
    margin-bottom: var(--space-lg);
  }

  .product-selector-mobile select {
    width: 100%;
    padding: var(--space-sm) var(--space-md);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text);
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    cursor: pointer;
  }

  .product-nav-desktop {
    display: none;
  }

  @media (min-width: 900px) {
    .product-selector-mobile {
      display: none;
    }

    .product-nav-desktop {
      display: block;
    }

    .changelog-sidebar {
      position: sticky;
      top: calc(var(--nav-height) + var(--space-xl));
      align-self: start;
      max-height: calc(100vh - var(--nav-height) - var(--space-2xl));
      overflow-y: auto;
      padding-right: var(--space-md);
    }
  }

  /* ── Product nav buttons ── */
  .nav-product-btn {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    border-left: 3px solid transparent;
    padding: var(--space-sm) var(--space-md);
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
    letter-spacing: 0.05em;
  }

  .nav-product-chevron {
    display: inline-block;
    font-size: 0.7rem;
    transition: transform 0.2s ease;
    flex-shrink: 0;
    width: 0.7rem;
    text-align: center;
  }

  .nav-product-btn.active .nav-product-chevron {
    transform: rotate(90deg);
  }

  .nav-product-count {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-dim);
    opacity: 0.6;
  }

  .nav-product-btn:hover {
    color: var(--color-primary);
    border-left-color: var(--color-primary);
    background: var(--color-surface);
  }

  .nav-product-btn.active {
    color: var(--color-primary);
    border-left-color: var(--color-primary);
    background: var(--color-surface);
  }

  .nav-product-nested {
    padding-left: calc(var(--space-md) + var(--space-sm));
    font-size: 0.5rem;
  }

  /* ── Group title (SDKs) ── */
  .nav-group-title {
    font-family: var(--font-pixel);
    font-size: 0.45rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-xs);
    padding: var(--space-xs) var(--space-md) var(--space-sm);
    border-bottom: 2px solid var(--color-border);
  }

  .nav-group-first {
    margin-top: 0;
  }

  /* ── Version lists ── */
  .version-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin-bottom: var(--space-xs);
    max-height: 200px;
    overflow-y: auto;
    overflow-x: hidden;
    transition: max-height 0.25s ease, opacity 0.2s ease, margin 0.25s ease;
    opacity: 1;
  }

  .version-list.collapsed {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    margin-bottom: 0;
  }

  .version-list li {
    display: flex;
    align-items: baseline;
  }

  .version-list a {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    padding: var(--space-xs) var(--space-sm);
    padding-left: calc(var(--space-md) + var(--space-sm));
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: all var(--transition-fast);
    flex: 1;
    min-width: 0;
  }

  .version-list a:hover {
    color: var(--color-primary);
    background: var(--color-surface);
  }

  .version-link-tag {
    flex-shrink: 0;
  }

  .version-link-date {
    font-size: 0.62rem;
    color: var(--color-text-dim);
  }

  /* ── Header ── */
  .changelog-header {
    margin-bottom: var(--space-3xl);
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-text-muted);
    display: inline-block;
    margin-bottom: var(--space-lg);
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .changelog-header h1 {
    margin-bottom: var(--space-md);
  }

  .accent {
    color: var(--color-primary);
  }

  .changelog-intro {
    font-size: 1rem;
    color: var(--color-text-muted);
  }

  .changelog-intro a {
    color: var(--color-secondary);
  }

  /* ── Article content ── */
  .changelog-content {
    max-width: 800px;
  }

  .changelog-content :global(h2) {
    font-family: var(--font-pixel);
    font-size: 0.85rem;
    color: var(--color-primary);
    margin: var(--space-3xl) 0 var(--space-md);
    padding-top: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 2px solid var(--color-border);
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    scroll-margin-top: calc(var(--nav-height) + var(--space-xl));
  }

  .changelog-content :global(h2:first-child) {
    margin-top: 0;
  }

  .changelog-content :global(.version-tag) {
    color: var(--color-text);
  }

  .changelog-content :global(.release-date) {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--color-text-dim);
  }

  .changelog-content :global(h3) {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    color: var(--color-text);
    margin: var(--space-xl) 0 var(--space-sm);
  }

  .changelog-content :global(h4) {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    margin: var(--space-lg) 0 var(--space-sm);
  }

  .changelog-content :global(p) {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .changelog-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-xl) 0;
  }

  .changelog-content :global(ul) {
    list-style: none;
    margin-bottom: var(--space-md);
  }

  .changelog-content :global(li) {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    padding: var(--space-xs) 0;
    padding-left: var(--space-lg);
    position: relative;
  }

  .changelog-content :global(li::before) {
    content: '›';
    position: absolute;
    left: var(--space-sm);
    color: var(--color-primary);
    font-weight: bold;
  }

  .changelog-content :global(pre) {
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    padding: var(--space-md);
    overflow-x: auto;
    margin-bottom: var(--space-md);
  }

  .changelog-content :global(pre code) {
    background: none;
    padding: 0;
    border: none;
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  .changelog-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-surface);
    padding: 0.15em 0.4em;
    border: 1px solid var(--color-border);
  }

  .changelog-content :global(a) {
    color: var(--color-secondary);
  }

  .changelog-content :global(strong) {
    color: var(--color-text);
  }
</style>
