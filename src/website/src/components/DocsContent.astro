<script>
  function initDocsSectionNav() {
    const sections = document.querySelectorAll<HTMLElement>('.docs-section');
    const sidebarLinks = document.querySelectorAll<HTMLAnchorElement>('.docs-nav a[data-section]');
    const mobileSelect = document.getElementById('docs-section-select') as HTMLSelectElement | null;

    // Pager elements
    const pagerNav = document.querySelector<HTMLElement>('.docs-pager');
    const pagerPrev = document.getElementById('pagerPrev') as HTMLAnchorElement | null;
    const pagerNext = document.getElementById('pagerNext') as HTMLAnchorElement | null;
    const pagerPrevTitle = document.getElementById('pagerPrevTitle');
    const pagerNextTitle = document.getElementById('pagerNextTitle');
    const sectionOrderData: { id: string; label: string }[] = pagerNav
      ? JSON.parse(pagerNav.dataset.sections || '[]')
      : [];

    function updatePager(sectionId: string) {
      const idx = sectionOrderData.findIndex((s) => s.id === sectionId);
      if (pagerPrev && pagerPrevTitle) {
        if (idx > 0) {
          pagerPrev.style.visibility = 'visible';
          pagerPrev.dataset.target = sectionOrderData[idx - 1].id;
          pagerPrevTitle.textContent = sectionOrderData[idx - 1].label;
        } else {
          pagerPrev.style.visibility = 'hidden';
        }
      }
      if (pagerNext && pagerNextTitle) {
        if (idx < sectionOrderData.length - 1) {
          pagerNext.style.visibility = 'visible';
          pagerNext.dataset.target = sectionOrderData[idx + 1].id;
          pagerNextTitle.textContent = sectionOrderData[idx + 1].label;
        } else {
          pagerNext.style.visibility = 'hidden';
        }
      }
    }

    function showSection(sectionId: string) {
      sections.forEach((s) => {
        s.classList.toggle('active', s.id === sectionId);
      });
      sidebarLinks.forEach((a) => {
        a.classList.toggle('active', a.dataset.section === sectionId);
      });
      if (mobileSelect) mobileSelect.value = sectionId;
      updatePager(sectionId);
      history.replaceState(null, '', `#${sectionId}`);
      // Scroll content area to top
      document.querySelector('.docs-content')?.scrollTo(0, 0);
      window.scrollTo(0, 0);
    }

    // Sidebar click
    sidebarLinks.forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const id = link.dataset.section;
        if (id) showSection(id);
      });
    });

    // Pager click
    [pagerPrev, pagerNext].forEach((btn) => {
      btn?.addEventListener('click', (e) => {
        e.preventDefault();
        const target = btn.dataset.target;
        if (target) showSection(target);
      });
    });

    // Mobile select
    mobileSelect?.addEventListener('change', () => {
      showSection(mobileSelect.value);
    });

    // Initial section from hash or default
    const hash = window.location.hash.replace('#', '');
    const validIds = Array.from(sections).map((s) => s.id);
    const initial = validIds.includes(hash) ? hash : 'overview';
    showSection(initial);

    // Handle browser back/forward
    window.addEventListener('hashchange', () => {
      const h = window.location.hash.replace('#', '');
      if (validIds.includes(h)) showSection(h);
    });
  }

  // Run on initial load and Astro page transitions
  initDocsSectionNav();
  document.addEventListener('astro:after-swap', initDocsSectionNav);

  // Enhance table accessibility: scope="col" on all th, plus scrollable wrappers
  document.querySelectorAll<HTMLTableElement>('.docs-table').forEach((table) => {
    table.querySelectorAll('thead th').forEach((th) => {
      th.setAttribute('scope', 'col');
    });

    if (!table.parentElement?.classList.contains('table-wrapper')) {
      const wrapper = document.createElement('div');
      wrapper.className = 'table-wrapper';
      wrapper.setAttribute('tabindex', '0');
      wrapper.setAttribute('role', 'region');
      wrapper.setAttribute('aria-label', table.querySelector('caption')?.textContent ?? 'data table');
      table.parentNode!.insertBefore(wrapper, table);
      wrapper.appendChild(table);
    }
  });
</script>
