---
import { localizedPath, useTranslations } from '../i18n/utils';
import CodeBlock from './CodeBlock.astro';

type CodeLang = 'python' | 'csharp' | 'typescript' | 'go' | 'java';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const sdkTabs = [
  {
    id: 'python',
    label: t.howItWorks.sdkTabPython,
    icon: '/sdk-python.svg',
    lang: 'python' as CodeLang,
    filename: 'settings.py',
    install: 'pip install envilder',
    pkg: 'https://pypi.org/project/envilder/',
    docsHash: 'sdk-python',
    status: 'available' as const,
    code: `from envilder import Envilder, SecretProviderType

# One-liner: load secrets into os.environ
Envilder.load("envilder.json")

# Or resolve as a dict without injecting
secrets = Envilder.resolve_file("envilder.json")

# Fluent builder with provider override
secrets = (
    Envilder.from_map_file("envilder.json")
    .with_provider(SecretProviderType.AZURE)
    .with_vault_url("https://my-vault.vault.azure.net")
    .inject()
)`,
  },
  {
    id: 'dotnet',
    label: t.howItWorks.sdkTabDotnet,
    icon: '/sdk-dotnet.svg',
    lang: 'csharp' as CodeLang,
    filename: 'Program.cs',
    install: 'dotnet add package Envilder',
    pkg: 'https://www.nuget.org/packages/Envilder',
    docsHash: 'sdk-dotnet',
    status: 'available' as const,
    code: `using Envilder;

var builder = WebApplication.CreateBuilder(args);

// Load secrets into IConfiguration
builder.Configuration.AddEnvilder("envilder.json");

// Register EnvilderClient in DI
builder.Services.AddEnvilder("envilder.json");

// --- Or standalone (no ASP.NET) ---

// One-liner: resolve + inject into Environment
Env.Load("envilder.json");

// Fluent builder with provider override
Env.FromMapFile("envilder.json")
    .WithProvider(SecretProviderType.Azure)
    .WithVaultUrl("https://my-vault.vault.azure.net")
    .Inject();`,
  },
  {
    id: 'nodejs',
    label: t.howItWorks.sdkTabNodejs,
    icon: '/sdk-logo.svg',
    lang: 'typescript' as CodeLang,
    filename: 'config.ts',
    install: 'npm install @envilder/sdk',
    pkg: 'https://www.npmjs.com/package/@envilder/sdk',
    docsHash: 'sdk-nodejs',
    status: 'available' as const,
    code: `import { Envilder, SecretProviderType } from '@envilder/sdk';

// One-liner: resolve + inject into process.env
await Envilder.load('envilder.json');

// Or resolve as a Map without injecting
const secrets = await Envilder.resolveFile('envilder.json');

// Fluent builder with provider override
const override = await Envilder.fromMapFile('envilder.json')
  .withProvider(SecretProviderType.Azure)
  .withVaultUrl('https://my-vault.vault.azure.net')
  .inject();`,
  },
  {
    id: 'go',
    label: 'Go',
    icon: '/sdk-go.svg',
    lang: 'go' as CodeLang,
    filename: 'main.go',
    install: '',
    pkg: '',
    docsHash: '',
    status: 'planned' as const,
    code: '',
  },
  {
    id: 'java',
    label: 'Java',
    icon: '/sdk-java.svg',
    lang: 'java' as CodeLang,
    filename: 'App.java',
    install: '',
    pkg: '',
    docsHash: '',
    status: 'planned' as const,
    code: '',
  },
];
---

<section class="section section-alt" id="how-it-works">
  <div class="container">
    <div class="section-title">
      <h2>{t.howItWorks.title}<span>{t.howItWorks.titleAccent}</span></h2>
      <p class="section-subtitle">
        {t.howItWorks.subtitle}
      </p>
    </div>

    <div class="steps">
      <div class="step">
        <div class="step-number">
          <span class="step-label">{t.howItWorks.stepLabel}</span>
          <span>01</span>
        </div>
        <div class="step-content">
          <h3>{t.howItWorks.steps[0].title}</h3>
          <p>
            {t.howItWorks.steps[0].description}
          </p>
          <CodeBlock lang="json" filename="envilder.json" code={`{
  "DB_PASSWORD": "/my-app/prod/db-password",
  "API_KEY":     "/my-app/prod/api-key",
  "SECRET_TOKEN": "/my-app/prod/secret-token"
}`} />
        </div>
      </div>

      <div class="step-connector">
        <span class="connector-line"></span>
        <span class="connector-arrow">▼</span>
        <span class="connector-line"></span>
      </div>

      <div class="step">
        <div class="step-number">
          <span class="step-label">{t.howItWorks.stepLabel}</span>
          <span>02</span>
        </div>
        <div class="step-content">
          <h3>{t.howItWorks.steps[1].title}</h3>
          <p>
            {t.howItWorks.steps[1].description}
          </p>
          <CodeBlock lang="bash" filename="terminal" code={`$ envilder

${t.howItWorks.terminalFetched1}
${t.howItWorks.terminalFetched2}
${t.howItWorks.terminalFetched3}
${t.howItWorks.terminalWritten}`} />
        </div>
      </div>

      <div class="step-connector">
        <span class="connector-line"></span>
        <span class="connector-arrow">▼</span>
        <span class="connector-line"></span>
      </div>

      <div class="step step-sdk">
        <div class="step-number">
          <span class="step-label">{t.howItWorks.stepLabel}</span>
          <span>03</span>
        </div>
        <div class="step-content">
          <h3>{t.howItWorks.steps[2].title}</h3>
          <p>
            {t.howItWorks.steps[2].description}
          </p>

          <div class="sdk-tabs-wrapper">
            <div class="sdk-tab-list" role="tablist">
              {sdkTabs.map((sdk, i) => (
                <button
                  id={`hiw-sdk-tab-${sdk.id}`}
                  role="tab"
                  class:list={['sdk-tab', { active: i === 0, 'sdk-tab-disabled': sdk.status === 'planned' }]}
                  aria-selected={i === 0 ? 'true' : 'false'}
                  aria-controls={sdk.status === 'available' ? `hiw-sdk-panel-${sdk.id}` : undefined}
                  aria-disabled={sdk.status === 'planned' ? 'true' : undefined}
                  tabindex={i === 0 ? 0 : -1}
                  data-hiw-sdk-tab={sdk.id}
                  type="button"
                  disabled={sdk.status === 'planned'}
                >
                  <img src={sdk.icon} alt="" class="sdk-tab-icon" width="18" height="18" />
                  <span class="sdk-tab-label">{sdk.label}</span>
                  {sdk.status === 'planned' && (
                    <span class="sdk-badge badge-muted">{t.sdks.planned}</span>
                  )}
                </button>
              ))}
            </div>

            <div class="sdk-panels">
              {sdkTabs.filter(sdk => sdk.status === 'available').map((sdk, i) => (
                <div
                  id={`hiw-sdk-panel-${sdk.id}`}
                  role="tabpanel"
                  aria-labelledby={`hiw-sdk-tab-${sdk.id}`}
                  tabindex="0"
                  class:list={['sdk-panel', { active: i === 0 }]}
                  data-hiw-sdk-panel={sdk.id}
                >
                  <div class="sdk-panel-header">
                    <span class="sdk-badge badge-primary">{t.sdks.available}</span>
                    <a href={`${localizedPath(lang, '/docs')}#${sdk.docsHash}`} class="sdk-link">
                      {t.sdks.docsLink} →
                    </a>
                    <a href={sdk.pkg} target="_blank" rel="noopener noreferrer" class="sdk-link">
                      📦 {t.sdks.packageLink}
                    </a>
                  </div>

                  <div class="sdk-panel-install">
                    <CodeBlock lang="bash" code={sdk.install} />
                  </div>

                  <CodeBlock lang={sdk.lang} filename={sdk.filename} code={sdk.code} />
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="step-connector">
        <span class="connector-line"></span>
        <span class="connector-arrow">▼</span>
        <span class="connector-line"></span>
      </div>

      <div class="step">
        <div class="step-number">
          <span class="step-label">{t.howItWorks.stepLabel}</span>
          <span>04</span>
        </div>
        <div class="step-content">
          <h3>{t.howItWorks.steps[3].title}</h3>
          <p>
            {t.howItWorks.steps[3].description}
          </p>
          <CodeBlock lang="bash" filename="terminal" code={`$ envilder --push

${t.howItWorks.pushTerminalPushed1}
${t.howItWorks.pushTerminalPushed2}
${t.howItWorks.pushTerminalPushed3}`} />
        </div>
      </div>

      <div class="step-connector">
        <span class="connector-line"></span>
        <span class="connector-arrow">▼</span>
        <span class="connector-line"></span>
      </div>

      <div class="step step-final">
        <div class="step-number">
          <span class="step-label">{t.howItWorks.stepLabel}</span>
          <span>05</span>
        </div>
        <div class="step-content">
          <h3>{t.howItWorks.steps[4].title}</h3>
          <p>
            {t.howItWorks.steps[4].description}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .steps {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    max-width: 720px;
    margin: 0 auto;
  }

  .step {
    display: flex;
    gap: var(--space-xl);
    width: 100%;
    align-items: flex-start;
    min-width: 0;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    padding: var(--space-lg);
  }

  .step-number {
    flex-shrink: 0;
    width: 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    background: var(--color-primary);
    border: 2px solid var(--color-primary);
    box-shadow: var(--pixel-shadow-primary);
    padding: var(--space-sm) 0;
  }

  .step-label {
    font-family: var(--font-pixel);
    font-size: 0.4rem;
    color: var(--color-btn-text);
    opacity: 0.75;
    letter-spacing: 0.05em;
  }

  .step-number > span:not(.step-label) {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    color: var(--color-btn-text);
  }

  .step-content {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .step-content h3 {
    color: var(--color-text);
    font-size: 1.1rem;
  }

  .step-content p {
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .step-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-sm) 0;
    margin-left: calc(var(--space-lg) + 28px);
    width: 2px;
  }

  .connector-line {
    width: 2px;
    height: 12px;
    background: var(--color-border);
  }

  .connector-arrow {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: var(--color-primary);
    padding: 2px 0;
  }

  @media (max-width: 640px) {
    .step {
      flex-direction: column;
      gap: var(--space-md);
      overflow: hidden;
    }

    .step-content {
      overflow-x: hidden;
      width: 100%;
    }

    .step-connector {
      margin-left: 0;
      flex-direction: row;
      width: auto;
      gap: var(--space-sm);
      padding: var(--space-sm) 0;
    }

    .connector-line {
      width: 16px;
      height: 2px;
    }
  }

  .step-final {
    border-color: var(--color-primary);
  }

  .step-sdk {
    overflow: visible;
  }

  .sdk-tabs-wrapper {
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    margin-top: var(--space-sm);
  }

  .sdk-tab-list {
    display: flex;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-bottom: 2px solid var(--color-border);
    scrollbar-width: none;
  }

  .sdk-tab-list::-webkit-scrollbar {
    display: none;
  }

  .sdk-tab {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-md);
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    background: transparent;
    color: var(--color-text-muted);
    border: none;
    border-bottom: 3px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    position: relative;
    margin-bottom: -2px;
  }

  .sdk-tab:hover:not(:disabled) {
    color: var(--color-text);
    background: var(--color-surface-alt);
  }

  .sdk-tab.active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
    background: var(--color-surface);
  }

  .sdk-tab-disabled {
    opacity: 0.35;
    cursor: default;
    pointer-events: none;
  }

  .sdk-tab-icon {
    width: 18px;
    height: 18px;
    object-fit: contain;
  }

  .sdk-tab-label {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
  }

  .sdk-badge {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    padding: 1px var(--space-xs);
    border-radius: 2px;
  }

  .badge-primary {
    background: var(--color-primary);
    color: var(--color-btn-text);
  }

  .badge-muted {
    background: var(--color-surface);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .sdk-panels {
    padding: var(--space-md);
  }

  .sdk-panel {
    display: none;
  }

  .sdk-panel.active {
    display: block;
  }

  .sdk-panel-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    flex-wrap: wrap;
  }

  .sdk-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-primary);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  .sdk-link:hover {
    opacity: 0.7;
  }

  .sdk-panel-install {
    margin-bottom: var(--space-md);
  }
</style>

<script>
  function initHiwSdkTabs() {
    const wrappers = document.querySelectorAll('.step-sdk .sdk-tabs-wrapper');
    wrappers.forEach((wrapper) => {
      if ((wrapper as HTMLElement).dataset.hiwSdkInit) return;
      (wrapper as HTMLElement).dataset.hiwSdkInit = 'true';

      const tabs = Array.from(
        wrapper.querySelectorAll<HTMLButtonElement>('.sdk-tab:not(:disabled)'),
      );
      const panels = wrapper.querySelectorAll<HTMLElement>('.sdk-panel');

      function activateTab(tab: HTMLButtonElement) {
        const id = tab.getAttribute('data-hiw-sdk-tab');

        tabs.forEach((t) => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
          t.setAttribute('tabindex', '-1');
        });
        panels.forEach((p) => p.classList.remove('active'));

        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        tab.setAttribute('tabindex', '0');

        const panel = wrapper.querySelector(`[data-hiw-sdk-panel="${id}"]`);
        if (panel) panel.classList.add('active');
      }

      tabs.forEach((tab, index) => {
        tab.addEventListener('click', () => activateTab(tab));
        tab.addEventListener('keydown', (event) => {
          if (
            event.key !== 'ArrowRight' &&
            event.key !== 'ArrowLeft' &&
            event.key !== 'Home' &&
            event.key !== 'End'
          ) {
            return;
          }

          event.preventDefault();
          let nextIndex = index;

          if (event.key === 'ArrowRight') {
            nextIndex = (index + 1) % tabs.length;
          } else if (event.key === 'ArrowLeft') {
            nextIndex = (index - 1 + tabs.length) % tabs.length;
          } else if (event.key === 'Home') {
            nextIndex = 0;
          } else if (event.key === 'End') {
            nextIndex = tabs.length - 1;
          }

          const nextTab = tabs[nextIndex];
          nextTab.focus();
          activateTab(nextTab);
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initHiwSdkTabs);
  initHiwSdkTabs();
</script>
