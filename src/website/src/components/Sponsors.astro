---
import { useTranslations } from '../i18n/utils';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
---

<section class="sponsors">
  <div class="container">
    <p class="sponsors-label">{t.sponsors.title}</p>
    <a
      href="https://localstack.cloud"
      target="_blank"
      rel="noopener noreferrer"
      class="sponsor-link"
    >
      <img
        id="sponsor-logo"
        class="sponsor-logo"
        src="/localstack-on-dark.svg"
        alt={t.sponsors.localstackAlt}
        loading="lazy"
      />
    </a>
    <script>
      (function () {
        const logo = document.getElementById('sponsor-logo') as HTMLImageElement;
        if (!logo) return;
        const update = () => {
          const isLight = document.documentElement.dataset.theme === 'light';
          logo.src = isLight
            ? '/localstack-on-light.svg'
            : '/localstack-on-dark.svg';
        };
        update();
        new MutationObserver(update).observe(document.documentElement, {
          attributes: true,
          attributeFilter: ['data-theme'],
        });
      })();
    </script>
  </div>
</section>

<style>
  .sponsors {
    padding: var(--space-xl) 0;
    border-bottom: 2px solid var(--color-border);
  }

  .sponsors .container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .sponsors-label {
    font-family: var(--font-pixel);
    font-size: clamp(0.75rem, 1.2vw, 0.85rem);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 0;
  }

  .sponsor-link {
    display: flex;
    align-items: center;
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }

  .sponsor-link:hover {
    opacity: 1;
  }

  .sponsor-logo {
    max-width: 160px;
    height: auto;
  }

  @media (min-width: 640px) {
    .sponsor-logo {
      max-width: 200px;
    }
  }
</style>
