---
import { localizedPath, useTranslations } from '../i18n/utils';
import CodeBlock from './CodeBlock.astro';
import Footer from './Footer.astro';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const azRbacAssign = `az role assignment create \\
  --role "Key Vault Secrets Officer" \\
  --assignee {YOUR_OBJECT_ID} \\
  --scope /subscriptions/{SUB}/resourceGroups/{RG}/providers/Microsoft.KeyVault/vaults/{VAULT}`;

const azVaultShow = `az keyvault show --name {VAULT_NAME} \\
  --query properties.enableRbacAuthorization`;

const azVaultPolicy = `az keyvault set-policy \\
  --name {VAULT_NAME} \\
  --object-id {YOUR_OBJECT_ID} \\
  --secret-permissions get set list`;

const pushSingleCmd =
  'envilder --push --key=API_KEY --value={SECRET} --secret-path=/myapp/api/key';

const sectionOrder = [
  { id: 'overview', label: t.docs.overviewTitle },
  { id: 'requirements', label: t.docs.sidebarRequirements },
  { id: 'installation', label: t.docs.sidebarInstallation },
  { id: 'credentials', label: t.docs.sidebarCredentials },
  { id: 'permissions', label: t.docs.sidebarPermissions },
  { id: 'mapping-file', label: t.docs.sidebarMappingFile },
  { id: 'pull-command', label: t.docs.sidebarPullCommand },
  { id: 'push-command', label: t.docs.sidebarPushCommand },
  { id: 'push-single', label: t.docs.sidebarPushSingle },
  { id: 'sdk-dotnet', label: t.docs.sidebarSdkDotnet },
  { id: 'sdk-python', label: t.docs.sidebarSdkPython },
  { id: 'gha-setup', label: t.docs.sidebarGhaSetup },
  { id: 'gha-basic', label: t.docs.sidebarGhaBasic },
  { id: 'gha-multi-env', label: t.docs.sidebarGhaMultiEnv },
  { id: 'gha-azure', label: t.docs.sidebarGhaAzure },
  { id: 'gha-inputs', label: t.docs.sidebarGhaInputs },
  { id: 'config-priority', label: t.docs.sidebarConfigPriority },
  { id: 'azure-setup', label: t.docs.sidebarAzureSetup },
];
---

<main class="docs-page" id="main-content">
  <div class="docs-layout">

    <!-- Mobile section selector -->
    <div class="docs-mobile-select">
      <select id="docs-section-select" aria-label="Select section">
        <optgroup label={t.docs.sidebarGettingStarted}>
          <option value="overview">{t.docs.overviewTitle}</option>
          <option value="requirements">{t.docs.sidebarRequirements}</option>
          <option value="installation">{t.docs.sidebarInstallation}</option>
          <option value="credentials">{t.docs.sidebarCredentials}</option>
          <option value="permissions">{t.docs.sidebarPermissions}</option>
        </optgroup>
        <optgroup label={t.docs.sidebarCli}>
          <option value="mapping-file">{t.docs.sidebarMappingFile}</option>
          <option value="pull-command">{t.docs.sidebarPullCommand}</option>
          <option value="push-command">{t.docs.sidebarPushCommand}</option>
          <option value="push-single">{t.docs.sidebarPushSingle}</option>
        </optgroup>
        <optgroup label={t.docs.sidebarSdks}>
          <option value="sdk-dotnet">{t.docs.sidebarSdkDotnet}</option>
          <option value="sdk-python">{t.docs.sidebarSdkPython}</option>
        </optgroup>
        <optgroup label={t.docs.sidebarGha}>
          <option value="gha-setup">{t.docs.sidebarGhaSetup}</option>
          <option value="gha-basic">{t.docs.sidebarGhaBasic}</option>
          <option value="gha-multi-env">{t.docs.sidebarGhaMultiEnv}</option>
          <option value="gha-azure">{t.docs.sidebarGhaAzure}</option>
          <option value="gha-inputs">{t.docs.sidebarGhaInputs}</option>
        </optgroup>
        <optgroup label={t.docs.sidebarReference}>
          <option value="config-priority">{t.docs.sidebarConfigPriority}</option>
          <option value="azure-setup">{t.docs.sidebarAzureSetup}</option>
        </optgroup>
      </select>
    </div>

    <!-- Sidebar navigation -->
    <aside class="docs-sidebar">
      <nav class="docs-nav">
        <p class="nav-section-title">{t.docs.sidebarGettingStarted}</p>
        <ul>
          <li><a href="#overview" data-section="overview">{t.docs.overviewTitle}</a></li>
          <li><a href="#requirements" data-section="requirements">{t.docs.sidebarRequirements}</a></li>
          <li><a href="#installation" data-section="installation">{t.docs.sidebarInstallation}</a></li>
          <li><a href="#credentials" data-section="credentials">{t.docs.sidebarCredentials}</a></li>
          <li><a href="#permissions" data-section="permissions">{t.docs.sidebarPermissions}</a></li>
        </ul>

        <p class="nav-section-title">{t.docs.sidebarCli}</p>
        <ul>
          <li><a href="#mapping-file" data-section="mapping-file">{t.docs.sidebarMappingFile}</a></li>
          <li><a href="#pull-command" data-section="pull-command">{t.docs.sidebarPullCommand}</a></li>
          <li><a href="#push-command" data-section="push-command">{t.docs.sidebarPushCommand}</a></li>
          <li><a href="#push-single" data-section="push-single">{t.docs.sidebarPushSingle}</a></li>
        </ul>

        <p class="nav-section-title">{t.docs.sidebarSdks}</p>
        <ul>
          <li><a href="#sdk-dotnet" data-section="sdk-dotnet">{t.docs.sidebarSdkDotnet}</a></li>
          <li><a href="#sdk-python" data-section="sdk-python">{t.docs.sidebarSdkPython}</a></li>
        </ul>

        <p class="nav-section-title">{t.docs.sidebarGha}</p>
        <ul>
          <li><a href="#gha-setup" data-section="gha-setup">{t.docs.sidebarGhaSetup}</a></li>
          <li><a href="#gha-basic" data-section="gha-basic">{t.docs.sidebarGhaBasic}</a></li>
          <li><a href="#gha-multi-env" data-section="gha-multi-env">{t.docs.sidebarGhaMultiEnv}</a></li>
          <li><a href="#gha-azure" data-section="gha-azure">{t.docs.sidebarGhaAzure}</a></li>
          <li><a href="#gha-inputs" data-section="gha-inputs">{t.docs.sidebarGhaInputs}</a></li>
        </ul>

        <p class="nav-section-title">{t.docs.sidebarReference}</p>
        <ul>
          <li><a href="#config-priority" data-section="config-priority">{t.docs.sidebarConfigPriority}</a></li>
          <li><a href="#azure-setup" data-section="azure-setup">{t.docs.sidebarAzureSetup}</a></li>
        </ul>
      </nav>
    </aside>

    <!-- Main content -->
    <div class="docs-content">
      <div class="docs-header">
        <a href={localizedPath(lang, '/')} class="back-link">{t.docs.backToHome}</a>
        <h1><span class="accent">{t.docs.pageTitle}</span></h1>
        <p class="docs-intro">
          {t.docs.intro}
        </p>
      </div>

      <!-- ───── GETTING STARTED ───── -->

      <section id="overview" class="docs-section">
        <h2>{t.docs.overviewTitle}</h2>
        <p>{t.docs.overviewDesc}</p>
        <div class="overview-cards">
          <div class="overview-card overview-problem">
            <span class="overview-icon">⚠️</span>
            <p>{t.docs.overviewProblem}</p>
          </div>
          <div class="overview-card overview-solution">
            <span class="overview-icon">✅</span>
            <p>{t.docs.overviewSolution}</p>
          </div>
        </div>
      </section>

      <section id="requirements" class="docs-section">
        <h2>{t.docs.reqTitle}</h2>
        <ul class="docs-list">
          <li><strong>{t.docs.reqNode}</strong> — <a href="https://nodejs.org/" target="_blank" rel="noopener noreferrer">{t.docs.reqDownload}</a></li>
          <li><strong>{t.docs.reqAws}</strong> <em>({t.docs.reqAwsNote})</em> — <a href="https://docs.aws.amazon.com/cli/latest/userguide/getting-started-install.html" target="_blank" rel="noopener noreferrer">{t.docs.reqInstallGuide}</a></li>
          <li><strong>{t.docs.reqAzure}</strong> <em>({t.docs.reqAzureNote})</em> — <a href="https://learn.microsoft.com/en-us/cli/azure/install-azure-cli" target="_blank" rel="noopener noreferrer">{t.docs.reqInstallGuide}</a></li>
        </ul>
      </section>

      <section id="installation" class="docs-section">
        <h2>{t.docs.installTitle}</h2>
        <div class="install-options">
          <div class="install-option">
            <span class="install-label">pnpm</span>
            <CodeBlock lang="bash" code="pnpm add -g envilder" />
          </div>
          <div class="install-option">
            <span class="install-label">npm</span>
            <CodeBlock lang="bash" code="npm install -g envilder" />
          </div>
          <div class="install-option">
            <span class="install-label">npx</span>
            <CodeBlock lang="bash" code="npx envilder --help" />
          </div>
        </div>
      </section>

      <section id="credentials" class="docs-section">
        <h2>{t.docs.credTitle}</h2>

        <h3>{t.docs.credAwsTitle}</h3>
        <p>{t.docs.credAwsDesc}</p>
        <CodeBlock lang="bash" code="aws configure" />
        <p>{t.docs.credAwsProfile}</p>
        <CodeBlock lang="bash" code={`aws configure --profile dev-account

# Then pass it to envilder
envilder --map=param-map.json --envfile=.env --profile=dev-account`} />

        <h3>{t.docs.credAzureTitle}</h3>
        <p>{t.docs.credAzureDesc}</p>
        <CodeBlock lang="bash" code="az login" />
        <p>{t.docs.credAzureVault}</p>
      </section>

      <section id="permissions" class="docs-section">
        <h2>{t.docs.permTitle}</h2>

        <h3>{t.docs.permAwsTitle}</h3>
        <p>{t.docs.permAwsDesc}</p>
        <table class="docs-table">
          <thead>
            <tr><th>{t.docs.permOperation}</th><th>{t.docs.permPermission}</th></tr>
          </thead>
          <tbody>
            <tr><td>{t.docs.permPull}</td><td><code>ssm:GetParameter</code></td></tr>
            <tr><td>{t.docs.permPush}</td><td><code>ssm:PutParameter</code></td></tr>
          </tbody>
        </table>
        <p>{t.docs.permPolicyExample}</p>
        <CodeBlock lang="json" code={`{
  "Version": "2012-10-17",
  "Statement": [{
    "Effect": "Allow",
    "Action": ["ssm:GetParameter", "ssm:PutParameter"],
    "Resource": "arn:aws:ssm:us-east-1:123456789012:parameter/myapp/*"
  }]
}`} />

        <h3>{t.docs.permAzureTitle}</h3>
        <table class="docs-table">
          <thead>
            <tr><th>{t.docs.permOperation}</th><th>{t.docs.permPermission}</th></tr>
          </thead>
          <tbody>
            <tr><td>{t.docs.permPull}</td><td><strong>Get</strong></td></tr>
            <tr><td>{t.docs.permPush}</td><td><strong>Set</strong></td></tr>
          </tbody>
        </table>
        <p>{t.docs.permAzureRbac}</p>
        <CodeBlock lang="bash" code={azRbacAssign} />
        <p class="note">{t.docs.permAzurePullNote}</p>
      </section>

      <!-- ───── CLI ───── -->

      <section id="mapping-file" class="docs-section">
        <h2>{t.docs.mapTitle}</h2>
        <p>{t.docs.mapIntro}</p>

        <div class="callout">
          <span class="callout-icon">📄</span>
          <div>
            <strong>{t.docs.mapCalloutStructure}</strong> {t.docs.mapCalloutKey}
            {t.docs.mapCalloutValue}
          </div>
        </div>

        <h3>{t.docs.mapBasicTitle}</h3>
        <p>{t.docs.mapBasicDesc}</p>
        <CodeBlock lang="json" filename="param-map.json" code={`{
  "API_KEY": "/myapp/prod/api-key",
  "DB_PASSWORD": "/myapp/prod/db-password",
  "SECRET_TOKEN": "/myapp/prod/secret-token"
}`} />
        <p>{t.docs.mapBasicGenerates}</p>
        <CodeBlock lang="dotenv" filename=".env" code={`API_KEY={value from /myapp/prod/api-key}
DB_PASSWORD={value from /myapp/prod/db-password}
SECRET_TOKEN={value from /myapp/prod/secret-token}`} />

        <h3>{t.docs.mapConfigTitle}</h3>
        <p>{t.docs.mapConfigDesc}</p>

        <h4>{t.docs.mapConfigOptionsTitle}</h4>
        <table class="docs-table">
          <thead>
            <tr><th>{t.docs.mapThKey}</th><th>{t.docs.mapThType}</th><th>{t.docs.mapThDefault}</th><th>{t.docs.mapThDescription}</th></tr>
          </thead>
          <tbody>
            <tr>
              <td><code>provider</code></td>
              <td><code>"aws"</code> | <code>"azure"</code></td>
              <td><code>"aws"</code></td>
              <td>{t.docs.mapProviderDesc}</td>
            </tr>
            <tr>
              <td><code>vaultUrl</code></td>
              <td><code>string</code></td>
              <td>—</td>
              <td>{t.docs.mapVaultUrlDesc}</td>
            </tr>
            <tr>
              <td><code>profile</code></td>
              <td><code>string</code></td>
              <td>—</td>
              <td>{t.docs.mapProfileDesc}</td>
            </tr>
          </tbody>
        </table>

        <h3>{t.docs.mapAwsProfileTitle}</h3>
        <p>{t.docs.mapAwsProfileDesc}</p>
        <CodeBlock lang="json" filename="param-map.json" code={`{
  "$config": {
    "provider": "aws",
    "profile": "prod-account"
  },
  "API_KEY": "/myapp/prod/api-key",
  "DB_PASSWORD": "/myapp/prod/db-password"
}`} />
        <p>{t.docs.mapAwsProfileExplain}</p>

        <h3>{t.docs.mapAzureTitle}</h3>
        <p>{t.docs.mapAzureDesc}</p>
        <CodeBlock lang="json" filename="param-map.json" code={`{
  "$config": {
    "provider": "azure",
    "vaultUrl": "https://my-vault.vault.azure.net"
  },
  "API_KEY": "myapp-prod-api-key",
  "DB_PASSWORD": "myapp-prod-db-password"
}`} />

        <div class="callout callout-warning">
          <span class="callout-icon">⚠️</span>
          <div>
            <strong>{t.docs.mapAzureWarningTitle}</strong> {t.docs.mapAzureWarningDesc}
          </div>
        </div>

        <h3>{t.docs.mapDifferencesTitle}</h3>
        <table class="docs-table">
          <thead>
            <tr><th>{t.docs.mapThEmpty}</th><th>{t.docs.mapThAwsSsm}</th><th>{t.docs.mapThAzureKv}</th></tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>{t.docs.mapSecretPathFormat}</strong></td>
              <td>{t.docs.mapAwsPathFormat}<br/><code>/myapp/prod/api-key</code></td>
              <td>{t.docs.mapAzurePathFormat}<br/><code>myapp-prod-api-key</code></td>
            </tr>
            <tr>
              <td><strong>{t.docs.mapRequiredConfig}</strong></td>
              <td>{t.docs.mapAwsRequiredConfig}</td>
              <td><code>{t.docs.mapAzureRequiredConfig}</code></td>
            </tr>
            <tr>
              <td><strong>{t.docs.mapOptionalConfig}</strong></td>
              <td><code>profile</code></td>
              <td>—</td>
            </tr>
            <tr>
              <td><strong>{t.docs.mapAuthentication}</strong></td>
              <td>{t.docs.mapAwsAuth}</td>
              <td>{t.docs.mapAzureAuth}</td>
            </tr>
          </tbody>
        </table>

        <h3>{t.docs.mapMultiEnvTitle}</h3>
        <p>{t.docs.mapMultiEnvDesc}</p>
        <div class="multi-env-grid">
          <CodeBlock lang="json" filename="config/dev/param-map.json" code={`{
  "$config": {
    "provider": "aws",
    "profile": "dev-account"
  },
  "API_KEY": "/myapp/dev/api-key",
  "DB_PASSWORD": "/myapp/dev/db-password"
}`} />
          <CodeBlock lang="json" filename="config/prod/param-map.json" code={`{
  "$config": {
    "provider": "aws",
    "profile": "prod-account"
  },
  "API_KEY": "/myapp/prod/api-key",
  "DB_PASSWORD": "/myapp/prod/db-password"
}`} />
        </div>
        <p>{t.docs.mapMultiEnvThenPull}</p>
        <CodeBlock lang="bash" code={`# Development
envilder --map=config/dev/param-map.json --envfile=.env.dev

# Production
envilder --map=config/prod/param-map.json --envfile=.env.prod`} />

        <h3>{t.docs.mapOverrideTitle}</h3>
        <p>{t.docs.mapOverrideDesc}</p>
        <CodeBlock lang="bash" code={`# Uses $config from the map file as-is
envilder --map=param-map.json --envfile=.env

# Overrides provider and vault URL, ignoring $config
envilder --provider=azure \\
  --vault-url=https://other-vault.vault.azure.net \\
  --map=param-map.json --envfile=.env

# Overrides just the AWS profile
envilder --map=param-map.json --envfile=.env --profile=staging-account`} />

        <p class="note">{t.docs.mapPriorityNote}</p>
      </section>

      <section id="pull-command" class="docs-section">
        <h2>{t.docs.pullTitle}</h2>
        <p>{t.docs.pullDesc}</p>

        <CodeBlock lang="bash" code="envilder --map=param-map.json --envfile=.env" />

        <h3>{t.docs.pullOptions}</h3>
        <table class="docs-table">
          <thead>
            <tr><th>{t.docs.optionHeader}</th><th>{t.docs.mapThDescription}</th></tr>
          </thead>
          <tbody>
            <tr><td><code>--map</code></td><td>{t.docs.pullOptMap}</td></tr>
            <tr><td><code>--envfile</code></td><td>{t.docs.pullOptEnv}</td></tr>
            <tr><td><code>--provider</code></td><td>{t.docs.pullOptProvider}</td></tr>
            <tr><td><code>--vault-url</code></td><td>{t.docs.pullOptVault}</td></tr>
            <tr><td><code>--profile</code></td><td>{t.docs.pullOptProfile}</td></tr>
          </tbody>
        </table>

        <h3>{t.docs.pullExamples}</h3>
        <CodeBlock lang="bash" code={`# Default (AWS SSM)
envilder --map=param-map.json --envfile=.env

# With AWS profile
envilder --map=param-map.json --envfile=.env --profile=prod-account

# Azure via $config in map file
envilder --map=azure-param-map.json --envfile=.env

# Azure via CLI flags
envilder --provider=azure \\
  --vault-url=https://my-vault.vault.azure.net \\
  --map=param-map.json --envfile=.env`} />

        <h3>{t.docs.pullOutputTitle}</h3>
        <CodeBlock lang="dotenv" filename=".env" code={`# Generated by Envilder
API_KEY=abc123
DB_PASSWORD=secret456`} />
      </section>

      <section id="push-command" class="docs-section">
        <h2>{t.docs.pushTitle}</h2>
        <p>{t.docs.pushDesc}</p>

        <CodeBlock lang="bash" code="envilder --push --envfile=.env --map=param-map.json" />

        <h3>{t.docs.pushOptions}</h3>
        <table class="docs-table">
          <thead>
            <tr><th>{t.docs.optionHeader}</th><th>{t.docs.mapThDescription}</th></tr>
          </thead>
          <tbody>
            <tr><td><code>--push</code></td><td>{t.docs.pushOptPush}</td></tr>
            <tr><td><code>--envfile</code></td><td>{t.docs.pushOptEnv}</td></tr>
            <tr><td><code>--map</code></td><td>{t.docs.pushOptMap}</td></tr>
            <tr><td><code>--provider</code></td><td>{t.docs.pushOptProvider}</td></tr>
            <tr><td><code>--vault-url</code></td><td>{t.docs.pushOptVault}</td></tr>
            <tr><td><code>--profile</code></td><td>{t.docs.pushOptProfile}</td></tr>
          </tbody>
        </table>

        <h3>{t.docs.pushExamples}</h3>
        <CodeBlock lang="bash" code={`# Push to AWS SSM
envilder --push --envfile=.env --map=param-map.json

# With AWS profile
envilder --push --envfile=.env.prod --map=param-map.json --profile=prod-account

# Azure via $config in map file
envilder --push --envfile=.env --map=azure-param-map.json

# Azure via CLI flags
envilder --push --provider=azure \\
  --vault-url=https://my-vault.vault.azure.net \\
  --envfile=.env --map=param-map.json`} />
      </section>

      <section id="push-single" class="docs-section">
        <h2>{t.docs.pushSingleTitle}</h2>
        <p>{t.docs.pushSingleDesc}</p>

        <CodeBlock lang="bash" code={pushSingleCmd} />

        <h3>{t.docs.pushSingleOptions}</h3>
        <table class="docs-table">
          <thead>
            <tr><th>{t.docs.optionHeader}</th><th>{t.docs.mapThDescription}</th></tr>
          </thead>
          <tbody>
            <tr><td><code>--push</code></td><td>{t.docs.pushSingleOptPush}</td></tr>
            <tr><td><code>--key</code></td><td>{t.docs.pushSingleOptKey}</td></tr>
            <tr><td><code>--value</code></td><td>{t.docs.pushSingleOptValue}</td></tr>
            <tr><td><code>--secret-path</code></td><td>{t.docs.pushSingleOptPath}</td></tr>
            <tr><td><code>--provider</code></td><td>{t.docs.pushSingleOptProvider}</td></tr>
            <tr><td><code>--vault-url</code></td><td>{t.docs.pushSingleOptVault}</td></tr>
            <tr><td><code>--profile</code></td><td>{t.docs.pushSingleOptProfile}</td></tr>
          </tbody>
        </table>
      </section>

      <!-- ───── SDKs ───── -->

      <section id="sdk-dotnet" class="docs-section">
        <h2>{t.docs.sdkDotnetTitle}</h2>
        <p>{t.docs.sdkDotnetDesc}</p>
        <div class="sdk-badges">
          <a class="sdk-badge" href="https://www.nuget.org/packages/Envilder" target="_blank" rel="noopener noreferrer">📦 NuGet v0.1.0</a>
        </div>

        <h3>{t.docs.sdkDotnetInstall}</h3>
        <CodeBlock lang="bash" code="dotnet add package Envilder" />

        <h3>{t.docs.sdkDotnetOneLiner}</h3>
        <p>{t.docs.sdkDotnetOneLinerDesc}</p>
        <CodeBlock lang="csharp" code={`using Envilder;

// Resolve secrets and inject into Environment
Envilder.Load("secrets-map.json");

var dbPassword = Environment.GetEnvironmentVariable("DB_PASSWORD");`} />

        <h3>{t.docs.sdkDotnetResolve}</h3>
        <p>{t.docs.sdkDotnetResolveDesc}</p>
        <CodeBlock lang="csharp" code={`using Envilder;

var secrets = Envilder.ResolveFile("secrets-map.json");
var dbPassword = secrets["DB_PASSWORD"];`} />

        <h3>{t.docs.sdkDotnetFluent}</h3>
        <p>{t.docs.sdkDotnetFluentDesc}</p>
        <CodeBlock lang="csharp" code={`using Envilder;

var secrets = Envilder.FromFile("secrets-map.json")
    .WithProvider(SecretProviderType.Azure)
    .WithVaultUrl("https://my-vault.vault.azure.net")
    .Resolve();

// Or inject directly
Envilder.FromFile("secrets-map.json")
    .WithProfile("staging")
    .Inject();`} />

        <h3>{t.docs.sdkDotnetEnvLoading}</h3>
        <p>{t.docs.sdkDotnetEnvLoadingDesc}</p>
        <CodeBlock lang="csharp" code={`using Envilder;

var env = Environment.GetEnvironmentVariable("APP_ENV") ?? "development";

Envilder.Load(env, new Dictionary<string, string?>
{
    ["production"] = "prod-secrets.json",
    ["development"] = "dev-secrets.json",
    ["test"] = null,  // no secrets loaded
});`} />

        <h3>{t.docs.sdkDotnetValidation}</h3>
        <p>{t.docs.sdkDotnetValidationDesc}</p>
        <CodeBlock lang="csharp" code={`using Envilder;

var secrets = Envilder.ResolveFile("secrets-map.json");
secrets.ValidateSecrets(); // throws SecretValidationException if any value is empty`} />

        <h3>{t.docs.sdkDotnetQuickStartConfig}</h3>
        <p>{t.docs.sdkDotnetQuickStartConfigDesc}</p>
        <CodeBlock lang="csharp" code={`using Envilder;

var builder = WebApplication.CreateBuilder(args);
var mapFile = new MapFileParser().Parse(
    File.ReadAllText("secrets-map.json"));
var provider = SecretProviderFactory.Create(mapFile.Config);
builder.Configuration.AddEnvilder("secrets-map.json", provider);
var app = builder.Build();`} />

