{
	"compilerOptions": {
		"target": "ES2020",
		"module": "Node16",
		"lib": [
			"es2020",
			"dom"
		],
		"removeComments": true,
		"declaration": true,
		"strict": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"noImplicitThis": true,
		"alwaysStrict": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": false,
		"inlineSourceMap": true,
		"inlineSources": true,
		"experimentalDecorators": true,
		"strictPropertyInitialization": false,
		"typeRoots": [
			"../../node_modules/@types",
			"./node_modules/@types"
		],
		"types": [
			"node"
		],
		"outDir": "dist",
		"esModuleInterop": true,
		"composite": true,
		"paths": {
			"@envilder/shared-iac": [
				"./node_modules/@envilder/shared-iac"
			]
		},
		"resolveJsonModule": true,
		"moduleResolution": "node16",
		"isolatedModules": true,
		"skipLibCheck": true
	},
	"include": [
		"bin",
		"lib",
		"**/*.ts"
	],
	"exclude": [
		"node_modules",
		"cdk.out",
		"dist"
	]
}