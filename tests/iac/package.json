{
  "name": "@envilder/iac-tests",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "biome lint --config-path ./biome.jsonc ./bin ./lib --files-ignore-unknown=true",
    "lint:fix": "biome lint --fix --config-path ./biome.jsonc ./bin ./lib --files-ignore-unknown=true",
    "format": "biome format --config-path ./biome.jsonc ./bin ./lib --files-ignore-unknown=true",
    "format:write": "biome format --write --config-path ./biome.jsonc ./bin ./lib --files-ignore-unknown=true",
    "test": "cd ../.. && vitest run --reporter=verbose tests/iac/",
    "test:update": "cd ../.. && vitest run --reporter=verbose --update tests/iac/"
  },
  "devDependencies": {
    "aws-cdk-lib": "catalog:",
    "constructs": "catalog:",
    "typescript": "catalog:"
  }
}
